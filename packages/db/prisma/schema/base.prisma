  REJECTED
}

enum ContractStatus {
  UNSENT
  SENT
  CONCLUDED
  DRAFT
}

enum PaymentStatus {
  UNPAID
  PAID
}

enum BankAccountType {
  ORDINARY
  CURRENT
}

enum SubscriptionStatus {
  TRIAL       // 無料トライアル中（現在のテスト期間）
  ACTIVE      // 有料プランで課金中
  PAST_DUE    // 支払い遅延
  CANCELED    // 解約済み
