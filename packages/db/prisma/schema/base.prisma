}

// ============ V2 Enums ============

enum VerificationLevel {
  LEVEL_1  // メール + SMS認証
  LEVEL_2  // 本人確認書類
  LEVEL_3  // インボイス登録確認
}

enum AvailabilityStatus {
  AVAILABLE   // 空き
  BUSY        // 予定あり
  NEGOTIABLE  // 応相談
}

enum DocumentType {
  ORDER_SHEET    // 注文書
  DELIVERY_NOTE  // 納品書
  INVOICE        // 請求書
}

enum DocumentStatus {
  DRAFT      // 下書き
  ISSUED     // 発行済
  CONFIRMED  // 確認済
