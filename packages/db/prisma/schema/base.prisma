// ============ Generators & Datasource ============

generator defaultClient {
  provider        = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder"]
}

generator client {
  provider        = "prisma-client-js"
  engineType      = "client"
  output          = "../../../../apps/user/generated/prisma"
  previewFeatures = ["prismaSchemaFolder"]
}

generator adminClient {
  provider        = "prisma-client-js"
  engineType      = "client"
  output          = "../../../../apps/admin/generated/prisma"
  previewFeatures = ["prismaSchemaFolder"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ Enums ============

enum CompanyType {
  ORDERER
  CONTRACTOR
  BOTH
}

enum CompanyForm {
  CORPORATION
  INDIVIDUAL
}

enum UserRole {
  REPRESENTATIVE
  MANAGER
  OTHER
}

enum FactoryFloorStatus {
  DRAFT
  NOT_ORDERED
  ORDERED
  ORDER_REQUESTED
  CONFIRMED
  IN_PROGRESS
  INSPECTION
  COMPLETED
  DELIVERY_APPROVED
  INVOICED
  DEAL_COMPLETED
}

